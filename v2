        "import os\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "from sklearn.model_selection import StratifiedKFold\n",
        "from sklearn.metrics import mean_squared_error\n",
        "from scipy.optimize import minimize\n",
        "\n",
        "import lightgbm as lgb\n",
        "import xgboost as xgb\n",
        "from catboost import CatBoostRegressor\n",
        "\n",
        "\n",
        "# ============================================================\n",
        "# 1. Veri yükleme\n",
        "# ============================================================\n",
        "\n",
        "DATA_DIR = \"/kaggle/input/competitions/yzta-2026-datathon\"\n",
        "\n",
        "train = pd.read_csv(os.path.join(DATA_DIR, \"train.csv\"))\n",
        "test = pd.read_csv(os.path.join(DATA_DIR, \"test_x.csv\"))\n",
        "\n",
        "TARGET = \"bilissel_performans_skoru\"\n",
        "ID_COL = \"id\"\n",
        "\n",
        "test_ids = test[ID_COL].copy()\n",
        "\n",
        "y = train[TARGET].copy()\n",
        "X = train.drop(columns=[TARGET])\n",
        "X_test = test.copy()\n",
        "\n",
        "\n",
        "# ============================================================\n",
        "# 2. Temel kolon listeleri\n",
        "# ============================================================\n",
        "\n",
        "cat_cols_base = [\n",
        "    \"cinsiyet\",\n",
        "    \"meslek\",\n",
        "    \"ulke\",\n",
        "    \"kronotip\",\n",
        "    \"ruh_sagligi_durumu\",\n",
        "    \"mevsim\",\n",
        "    \"gun_tipi\"\n",
        "]\n",
        "\n",
        "num_cols_base = [c for c in X.columns if c not in cat_cols_base + [ID_COL]]\n",
        "\n",
        "\n",
        "# ============================================================\n",
        "# 3. Feature engineering\n",
        "# ============================================================\n",
        "\n",
        "# Sayısal medyanları sadece train üzerinden alıyoruz.\n",
        "num_medians = X[num_cols_base].median(numeric_only=True)\n",
        "\n",
        "\n",
        "def add_features(df):\n",
        "    df = df.copy()\n",
        "\n",
        "    # Sayısal hesaplamalarda NaN üretmemek için geçici doldurma\n",
        "    n = {}\n",
        "    for col in num_cols_base:\n",
        "        n[col] = df[col].fillna(num_medians[col])\n",
        "\n",
        "    # ----------------------------\n",
        "    # Eksik değer bayrakları\n",
        "    # ----------------------------\n",
        "    important_missing_cols = [\n",
        "        \"vucut_kitle_indeksi\",\n",
        "        \"stres_skoru\",\n",
        "        \"uyku_oncesi_kafein_mg\",\n",
        "        \"kronotip\",\n",
        "        \"meslek\",\n",
        "        \"ruh_sagligi_durumu\"\n",
        "    ]\n",
        "\n",
        "    for col in important_missing_cols:\n",
        "        if col in df.columns:\n",
        "            df[f\"{col}_missing\"] = df[col].isna().astype(int)\n",
        "\n",
        "    # ----------------------------\n",
        "    # Uyku kalitesi özellikleri\n",
        "    # ----------------------------\n",
        "    df[\"kaliteli_uyku_yuzdesi\"] = n[\"rem_yuzdesi\"] + n[\"derin_uyku_yuzdesi\"]\n",
        "    df[\"hafif_uyku_yuzdesi\"] = 100 - df[\"kaliteli_uyku_yuzdesi\"]\n",
        "    df[\"hafif_uyku_yuzdesi\"] = df[\"hafif_uyku_yuzdesi\"].clip(0, 100)\n",
        "\n",
        "    df[\"rem_derin_orani\"] = n[\"rem_yuzdesi\"] / (n[\"derin_uyku_yuzdesi\"] + 1)\n",
        "    df[\"uyku_bolunme_skoru\"] = (\n",
        "        n[\"gecelik_uyanma_sayisi\"] * 2\n",
        "        + n[\"uykuya_dalma_suresi_dk\"] / 20\n",
        "    )\n",
        "\n",
        "    df[\"uyku_verim_proxy\"] = (\n",
        "        df[\"kaliteli_uyku_yuzdesi\"]\n",
        "        - df[\"uyku_bolunme_skoru\"]\n",
        "        - n[\"hafta_sonu_uyku_farki_saat\"].abs()\n",
        "    )\n",
        "\n",
        "    # ----------------------------\n",
        "    # Stres / iş yükü özellikleri\n",
        "    # ----------------------------\n",
        "    df[\"stres_calisma_etkilesim\"] = n[\"stres_skoru\"] * n[\"gunluk_calisma_saati\"]\n",
        "    df[\"stres_uyku_bolunme\"] = n[\"stres_skoru\"] * df[\"uyku_bolunme_skoru\"]\n",
        "    df[\"calisma_saat_kare\"] = n[\"gunluk_calisma_saati\"] ** 2\n",
        "    df[\"stres_kare\"] = n[\"stres_skoru\"] ** 2\n",
        "\n",
        "    df[\"toplam_yorgunluk_proxy\"] = (\n",
        "        n[\"gunluk_calisma_saati\"]\n",
        "        + n[\"uykuya_dalma_suresi_dk\"] / 60\n",
        "        + n[\"gecelik_uyanma_sayisi\"] * 0.35\n",
        "        + n[\"stres_skoru\"] * 0.6\n",
        "    )\n",
        "\n",
        "    # ----------------------------\n",
        "    # Kafein / ekran özellikleri\n",
        "    # ----------------------------\n",
        "    df[\"ekran_saat\"] = n[\"uyku_oncesi_ekran_suresi_dk\"] / 60\n",
        "    df[\"kafein_ekran_yuku\"] = (\n",
        "        n[\"uyku_oncesi_kafein_mg\"] / 100\n",
        "        + n[\"uyku_oncesi_ekran_suresi_dk\"] / 60\n",
        "    )\n",
        "\n",
        "    df[\"kafein_stres_etkilesim\"] = n[\"uyku_oncesi_kafein_mg\"] * n[\"stres_skoru\"]\n",
        "    df[\"ekran_stres_etkilesim\"] = n[\"uyku_oncesi_ekran_suresi_dk\"] * n[\"stres_skoru\"]\n",
        "\n",
        "    # ----------------------------\n",
        "    # Aktivite özellikleri\n",
        "    # ----------------------------\n",
        "    df[\"log_adim\"] = np.log1p(n[\"gunluk_adim_sayisi\"])\n",
        "    df[\"adim_stres_orani\"] = n[\"gunluk_adim_sayisi\"] / (n[\"stres_skoru\"] + 1)\n",
        "    df[\"adim_calisma_orani\"] = n[\"gunluk_adim_sayisi\"] / (n[\"gunluk_calisma_saati\"] + 1)\n",
        "\n",
        "    df[\"aktivite_uyku_destegi\"] = (\n",
        "        df[\"log_adim\"] * df[\"kaliteli_uyku_yuzdesi\"]\n",
        "    ) / (n[\"stres_skoru\"] + 1)\n",
        "\n",
        "    # ----------------------------\n",
        "    # Şekerleme özellikleri\n",
        "    # ----------------------------\n",
        "    df[\"sekerleme_var\"] = (n[\"sekerleme_suresi_dk\"] > 0).astype(int)\n",
        "    df[\"uzun_sekerleme\"] = (n[\"sekerleme_suresi_dk\"] >= 60).astype(int)\n",
        "    df[\"sekerleme_saat\"] = n[\"sekerleme_suresi_dk\"] / 60\n",
        "    df[\"sekerleme_stres_etkilesim\"] = n[\"sekerleme_suresi_dk\"] * n[\"stres_skoru\"]\n",
        "\n",
        "    # ----------------------------\n",
        "    # Nabız / sağlık özellikleri\n",
        "    # ----------------------------\n",
        "    df[\"nabiz_stres_etkilesim\"] = n[\"dinlenik_nabiz_bpm\"] * n[\"stres_skoru\"]\n",
        "    df[\"nabiz_yas_orani\"] = n[\"dinlenik_nabiz_bpm\"] / (n[\"yas\"] + 1)\n",
        "\n",
        "    # ----------------------------\n",
        "    # Oda sıcaklığı\n",
        "    # 20-21 derece civarını nötr varsayan proxy\n",
        "    # ----------------------------\n",
        "    df[\"ideal_sicakliktan_sapma\"] = (n[\"oda_sicakligi_celsius\"] - 20.5).abs()\n",
        "    df[\"sicaklik_stres_etkilesim\"] = df[\"ideal_sicakliktan_sapma\"] * n[\"stres_skoru\"]\n",
        "\n",
        "    # ----------------------------\n",
        "    # Yaş / BMI grupları\n",
        "    # ----------------------------\n",
        "    df[\"yas_grubu\"] = pd.cut(\n",
        "        n[\"yas\"],\n",
        "        bins=[0, 25, 35, 45, 55, 100],\n",
        "        labels=[\"genc\", \"genc_yetiskin\", \"yetiskin\", \"orta_yas\", \"ileri_yas\"]\n",
        "    ).astype(str)\n",
        "\n",
        "    df[\"bmi_grubu\"] = pd.cut(\n",
        "        n[\"vucut_kitle_indeksi\"],\n",
        "        bins=[0, 18.5, 25, 30, 100],\n",
        "        labels=[\"zayif\", \"normal\", \"fazla_kilo\", \"obez\"]\n",
        "    ).astype(str)\n",
        "\n",
        "    # ----------------------------\n",
        "    # Kategorik etkileşimler\n",
        "    # ----------------------------\n",
        "    df[\"kronotip_gun_tipi\"] = (\n",
        "        df[\"kronotip\"].fillna(\"Eksik\").astype(str)\n",
        "        + \"_\"\n",
        "        + df[\"gun_tipi\"].fillna(\"Eksik\").astype(str)\n",
        "    )\n",
        "\n",
        "    df[\"meslek_stres_segment\"] = (\n",
        "        df[\"meslek\"].fillna(\"Eksik\").astype(str)\n",
        "        + \"_\"\n",
        "        + pd.cut(\n",
        "            n[\"stres_skoru\"],\n",
        "            bins=[-1, 3, 6, 10],\n",
        "            labels=[\"dusuk_stres\", \"orta_stres\", \"yuksek_stres\"]\n",
        "        ).astype(str)\n",
        "    )\n",
        "\n",
        "    df[\"ruh_kronotip\"] = (\n",
        "        df[\"ruh_sagligi_durumu\"].fillna(\"Eksik\").astype(str)\n",
        "        + \"_\"\n",
        "        + df[\"kronotip\"].fillna(\"Eksik\").astype(str)\n",
        "    )\n",
        "\n",
        "    return df\n",
        "\n",
        "\n",
        "X = add_features(X)\n",
        "X_test = add_features(X_test)\n",
        "\n",
        "\n",
        "# ============================================================\n",
        "# 4. Frequency encoding\n",
        "# ============================================================\n",
        "\n",
        "cat_cols = cat_cols_base + [\n",
        "    \"yas_grubu\",\n",
        "    \"bmi_grubu\",\n",
        "    \"kronotip_gun_tipi\",\n",
        "    \"meslek_stres_segment\",\n",
        "    \"ruh_kronotip\"\n",
        "]\n",
        "\n",
        "for col in cat_cols:\n",
        "    X[col] = X[col].fillna(\"Eksik\").astype(str)\n",
        "    X_test[col] = X_test[col].fillna(\"Eksik\").astype(str)\n",
        "\n",
        "    freq = pd.concat([X[col], X_test[col]], axis=0).value_counts(normalize=True)\n",
        "    X[f\"{col}_freq\"] = X[col].map(freq).astype(float)\n",
        "    X_test[f\"{col}_freq\"] = X_test[col].map(freq).astype(float)\n",
        "\n",
        "\n",
        "# ID modelden çıkarılır\n",
        "X = X.drop(columns=[ID_COL])\n",
        "X_test = X_test.drop(columns=[ID_COL])\n",
        "\n",
        "# Kategorikleri category tipine çevir\n",
        "for col in cat_cols:\n",
        "    X[col] = X[col].astype(\"category\")\n",
        "    X_test[col] = X_test[col].astype(\"category\")\n",
        "\n",
        "\n",
        "# ============================================================\n",
        "# 5. CV ayarı\n",
        "# ============================================================\n",
        "\n",
        "N_SPLITS = 7\n",
        "RANDOM_STATE = 42\n",
        "\n",
        "# Regresyon için hedefi bin'leyip StratifiedKFold kullanıyoruz.\n",
        "y_bins = pd.qcut(y, q=10, labels=False, duplicates=\"drop\")\n",
        "\n",
        "skf = StratifiedKFold(\n",
        "    n_splits=N_SPLITS,\n",
        "    shuffle=True,\n",
        "    random_state=RANDOM_STATE\n",
        ")\n",
        "\n",
        "\n",
        "# ============================================================\n",
        "# 6. OOF ve test tahminleri\n",
        "# ============================================================\n",
        "\n",
        "models = [\"lgbm\", \"cat\", \"xgb\"]\n",
        "\n",
        "oof = {m: np.zeros(len(X)) for m in models}\n",
        "test_pred = {m: np.zeros(len(X_test)) for m in models}\n",
        "\n",
        "scores = {m: [] for m in models}\n",
        "\n",
        "\n",
        "def rmse(a, b):\n",
        "    return np.sqrt(mean_squared_error(a, b))\n",
        "\n",
        "\n",
        "print(\"Eğitim başlıyor...\\n\")\n",
        "\n",
        "for fold, (tr_idx, val_idx) in enumerate(skf.split(X, y_bins), 1):\n",
        "    print(f\"========== Fold {fold}/{N_SPLITS} ==========\")\n",
        "\n",
        "    X_tr, X_val = X.iloc[tr_idx], X.iloc[val_idx]\n",
        "    y_tr, y_val = y.iloc[tr_idx], y.iloc[val_idx]\n",
        "\n",
        "    # ----------------------------\n",
        "    # LightGBM\n",
        "    # ----------------------------\n",
        "    lgbm_model = lgb.LGBMRegressor(\n",
        "        objective=\"regression\",\n",
        "        metric=\"rmse\",\n",
        "        n_estimators=5000,\n",
        "        learning_rate=0.015,\n",
        "        num_leaves=48,\n",
        "        max_depth=-1,\n",
        "        min_child_samples=35,\n",
        "        subsample=0.85,\n",
        "        subsample_freq=1,\n",
        "        colsample_bytree=0.85,\n",
        "        reg_alpha=0.05,\n",
        "        reg_lambda=1.5,\n",
        "        random_state=RANDOM_STATE + fold,\n",
        "        verbose=-1\n",
        "    )\n",
        "\n",
        "    lgbm_model.fit(\n",
        "        X_tr,\n",
        "        y_tr,\n",
        "        eval_set=[(X_val, y_val)],\n",
        "        eval_metric=\"rmse\",\n",
        "        categorical_feature=cat_cols,\n",
        "        callbacks=[\n",
        "            lgb.early_stopping(stopping_rounds=250, verbose=False),\n",
        "            lgb.log_evaluation(period=0)\n",
        "        ]\n",
        "    )\n",
        "\n",
        "    pred_val = lgbm_model.predict(X_val)\n",
        "    pred_test = lgbm_model.predict(X_test)\n",
        "\n",
        "    oof[\"lgbm\"][val_idx] = pred_val\n",
        "    test_pred[\"lgbm\"] += pred_test / N_SPLITS\n",
        "\n",
        "    fold_score = rmse(y_val, pred_val)\n",
        "    scores[\"lgbm\"].append(fold_score)\n",
        "    print(f\"LightGBM RMSE: {fold_score:.5f}\")\n",
        "\n",
        "    # ----------------------------\n",
        "    # CatBoost\n",
        "    # ----------------------------\n",
        "    cat_model = CatBoostRegressor(\n",
        "        loss_function=\"RMSE\",\n",
        "        eval_metric=\"RMSE\",\n",
        "        iterations=6000,\n",
        "        learning_rate=0.018,\n",
        "        depth=7,\n",
        "        l2_leaf_reg=5,\n",
        "        random_strength=0.7,\n",
        "        bagging_temperature=0.4,\n",
        "        border_count=254,\n",
        "        random_seed=RANDOM_STATE + fold,\n",
        "        cat_features=cat_cols,\n",
        "        verbose=False,\n",
        "        allow_writing_files=False\n",
        "    )\n",
        "\n",
        "    cat_model.fit(\n",
        "        X_tr,\n",
        "        y_tr,\n",
        "        eval_set=(X_val, y_val),\n",
        "        early_stopping_rounds=300,\n",
        "        use_best_model=True\n",
        "    )\n",
        "\n",
        "    pred_val = cat_model.predict(X_val)\n",
        "    pred_test = cat_model.predict(X_test)\n",
        "\n",
        "    oof[\"cat\"][val_idx] = pred_val\n",
        "    test_pred[\"cat\"] += pred_test / N_SPLITS\n",
        "\n",
        "    fold_score = rmse(y_val, pred_val)\n",
        "    scores[\"cat\"].append(fold_score)\n",
        "    print(f\"CatBoost RMSE: {fold_score:.5f}\")\n",
        "\n",
        "    # ----------------------------\n",
        "    # XGBoost\n",
        "    # ----------------------------\n",
        "    xgb_model = xgb.XGBRegressor(\n",
        "        objective=\"reg:squarederror\",\n",
        "        eval_metric=\"rmse\",\n",
        "        n_estimators=3500,\n",
        "        learning_rate=0.018,\n",
        "        max_depth=5,\n",
        "        min_child_weight=4,\n",
        "        subsample=0.85,\n",
        "        colsample_bytree=0.85,\n",
        "        reg_alpha=0.03,\n",
        "        reg_lambda=1.2,\n",
        "        tree_method=\"hist\",\n",
        "        enable_categorical=True,\n",
        "        random_state=RANDOM_STATE + fold\n",
        "    )\n",
        "\n",
        "    xgb_model.fit(\n",
        "        X_tr,\n",
        "        y_tr,\n",
        "        eval_set=[(X_val, y_val)],\n",
        "        verbose=False\n",
        "    )\n",
        "\n",
        "    pred_val = xgb_model.predict(X_val)\n",
        "    pred_test = xgb_model.predict(X_test)\n",
        "\n",
        "    oof[\"xgb\"][val_idx] = pred_val\n",
        "    test_pred[\"xgb\"] += pred_test / N_SPLITS\n",
        "\n",
        "    fold_score = rmse(y_val, pred_val)\n",
        "    scores[\"xgb\"].append(fold_score)\n",
        "    print(f\"XGBoost RMSE:  {fold_score:.5f}\")\n",
        "    print()\n",
        "\n",
        "\n",
        "# ============================================================\n",
        "# 7. Model skorları\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n========== OOF Skorları ==========\")\n",
        "\n",
        "for m in models:\n",
